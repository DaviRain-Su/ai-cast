{
  "name": "ai-cast-cli",
  "version": "0.2.0",
  "description": "Publish AI-generated podcasts to Sui blockchain & Walrus storage. Agent-friendly CLI with JSON output mode.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DaviRain-Su/ai-cast.git",
    "directory": "cli"
  },
  "keywords": [
    "ai",
    "podcast",
    "sui",
    "walrus",
    "web3",
    "decentralized",
    "cli",
    "agent"
  ],
  "bin": {
    "ai-cast": "dist/index.js"
  },
  "main": "./dist/api.js",
  "exports": {
    ".": "./dist/api.js",
    "./cli": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.62.0",
    "@mysten/seal": "^1.1.1",
    "@mysten/sui": "^2.9.1",
    "@mysten/walrus": "^1.0.0",
    "chalk": "^5.4.1",
    "cheerio": "^1.2.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.4"
  }
}
